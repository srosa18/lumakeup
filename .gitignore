# pastas de ORIGINAIS que o cliente larga (nunca deletar; só ignorar do git/deploy):
# _src/ e pastas com acento tipo "serviços/". Ficam no disco, fora do repo.
/public/images/**/_src/**
/public/images/servicos/serviços/**
/public/images/beleza-discreta/novas/**

